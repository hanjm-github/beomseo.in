# API
# Change this per environment (local/staging/production).
VITE_API_URL="http://localhost:5000/"
VITE_ENABLE_API_MOCKS=0
# Sports league / field-trip FastAPI server URL (falls back to VITE_API_URL when omitted).
# VITE_SPORTS_LEAGUE_API_URL="http://localhost:8000"

# Analytics (Cloudflare Zaraz)
# 1: enabled, 0: disabled
VITE_ANALYTICS_ENABLED=1
# 1: allow event tracking in dev, 0: track only in production
VITE_ANALYTICS_ALLOW_IN_DEV=0
# Comma-separated hostnames. Use "*" to allow all hosts.
VITE_ANALYTICS_ALLOWED_HOSTS="beomseo.in"
# Sensitive payload keys to strip before tracking.
VITE_ANALYTICS_BLOCKED_KEYS="nickname,password,email,token,refresh_token,access_token"

# App display
VITE_APP_NAME="beomseo.in"
# External absolute asset URL allowlist for image/media rendering.
# Use comma-separated hostnames; supports wildcard entries like *.example.com
# Leave empty to allow all hosts.
VITE_ALLOWED_ASSET_HOSTS=""

# Feature limits
VITE_UPLOAD_MAX_ATTACHMENTS=5
VITE_UPLOAD_MAX_IMAGES=5
VITE_UPLOAD_MAX_FILE_SIZE_MB=10
VITE_PETITION_THRESHOLD_DEFAULT=50
